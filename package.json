{
  "name": "trie-app",
  "version": "0.1.0",
  "description": "trie desktop — experimental attention-map editor built on trie + opencode. Requires the trie package (uv tool install trie).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/computer-reinvention/trie-app.git"
  },
  "private": true,
  "main": "out/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:resources": "node scripts/build-resources.mjs",
    "build:icon": "node scripts/build-icon.mjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build:resources && npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/setup-opencode.mjs"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@iarna/toml": "^2.2.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/d3-force": "^3.0.10",
    "codemirror": "^6.0.2",
    "d3-force": "^3.0.0",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^9.0.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "electron": "^35.4.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "keytar": "^7.9.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "ai.trie.app",
    "productName": "trie",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "resources/opencode-server",
        "to": "opencode-server"
      },
      {
        "from": "resources/trie-mcp",
        "to": "trie-mcp"
      },
      {
        "from": "resources/trie-cli",
        "to": "trie-cli"
      }
    ],
    "files": [
      "out/**/*"
    ]
  }
}
